      <Markup>&lt;div class="dropdown"&gt;
  &lt;button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown"&gt;
    Markup Demo
  &lt;/button&gt;
  &lt;ul class="dropdown-menu"&gt;
    &lt;li&gt;&lt;a class="dropdown-item markup-item1" href="#"&gt;Show Chart&lt;/a&gt;&lt;/li&gt;
    &lt;li&gt;&lt;a class="dropdown-item markup-item2" href="#"&gt;Send Command&lt;/a&gt;&lt;/li&gt;
  &lt;/ul&gt;
&lt;/div&gt;</Markup>
      <Name />
      <ObjNum>0</ObjNum>
      <OutCnlNum>105</OutCnlNum>
      <PropertyBindings isArray="true" />
      <Script>class extends ComponentScript {
    domCreated(args) {
      args.component.dom.find(".markup-item1").on("click", () =&gt; {
        args.renderContext.viewHub.features.chart.show(args.component.properties.inCnlNum);
      });

      args.component.dom.find(".markup-item2").on("click", () =&gt; {
        args.renderContext.viewHub.features.command.show(args.component.properties.outCnlNum);
      });
    }

    domUpdated(args) {
    }

    dataUpdated(args) {
    }
}
</Script>
