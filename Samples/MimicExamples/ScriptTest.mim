            <Param4 />
            <Param5 />
            <Param6 />
            <Param7 />
            <Param8 />
            <Param9 />
          </UrlParams>
          <ViewID>0</ViewID>
          <Target>Self</Target>
          <ModalWidth>Normal</ModalWidth>
          <ModalHeight>0</ModalHeight>
        </LinkArgs>
        <Script>function (args) {
  console.log("Show/hide panel");
  const PANEL_ID = 2;
  const button = args.component;
  const mimic = button.getMimic();
  const panel = mimic.componentMap.get(PANEL_ID);
  const isVisible = !panel.properties.visible;      
  
  panel.properties.visible = isVisible;
  panel.customData.requireUpdate = true;

  button.properties.text = isVisible ? "Hide Panel" : "Show Panel";
  button.customData.requireUpdate = true;
}
</Script>
      </ClickAction>
      <CornerRadius>
