      </Location>
      <Name />
      <ObjNum>0</ObjNum>
      <OutCnlNum>0</OutCnlNum>
      <PropertyBindings isArray="true" />
      <Script>class extends ComponentScript {
  domCreated(args) {
    args.component.customData = {
      requireUpdate: false
    };
  }
  
  dataUpdated(args) {
    if (args.component.customData.requireUpdate) {
      args.component.customData.requireUpdate = false;
      args.propertyChanged = true;
    }
  }
}
</Script>
